# MySQL (projection DB)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=kronex
MYSQL_PASSWORD=kronex
MYSQL_DATABASE=kronex

# RabbitMQ
RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USER=kronex
RABBITMQ_PASSWORD=kronex
RABBITMQ_PREFETCH_COUNT=256
RABBITMQ_DATA_QUEUE=data_queue   # 계좌 등록·송금·주문
RABBITMQ_ADMIN_QUEUE=admin_queue # 상장·상폐·거래정지 등
RABBITMQ_EVENT_QUEUE=event_queue # 이벤트 발행

# WAL / snapshot
WAL_DIR=./data/wal
SNAPSHOT_INTERVAL=5m
